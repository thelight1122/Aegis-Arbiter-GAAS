{
  "name": "aegis-arbiter",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "server",
    "ui"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:server dev:ui",
    "dev:server": "npm run dev -w aegis-arbiter-server",
    "dev:ui": "npm run dev -w aegis-arbiter-ui",
    "build": "npm-run-all build:server build:ui",
    "build:server": "npm run build -w aegis-arbiter-server",
    "build:ui": "npm run build -w aegis-arbiter-ui"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}