# Aegis Arbiter environment variables
AEGIS_CWD=f:\\Git_Repository\\Aegis-Arbiter
AEGIS_CLI_PATH=dist/cli.js
VITE_API_BASE_URL=http://localhost:8787/api

# ---------------------------------------------------------------------------
# LLM Governance Proxy — set one provider and its credentials
# ---------------------------------------------------------------------------

# Active provider: "anthropic" | "openai" | "ollama"
# AEGIS_LLM_PROVIDER=anthropic

# Anthropic / Claude
# AEGIS_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI / GPT
# AEGIS_OPENAI_API_KEY=sk-...

# Ollama (local — must be a localhost URL for SSRF protection)
# AEGIS_OLLAMA_URL=http://localhost:11434

# Default model used when the client sends an empty model string
# AEGIS_LLM_DEFAULT_MODEL=claude-sonnet-4-5

# CORS — comma-separated list of allowed UI origins (default: localhost:5173,5174)
# AEGIS_CORS_ORIGINS=http://localhost:5173,http://localhost:5174