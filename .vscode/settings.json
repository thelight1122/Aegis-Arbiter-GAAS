{
  "typescript.tsserver.experimental.enableProjectDiagnostics": false,
  "typescript.tsserver.exclude": ["**/node_modules/**"],

  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.git/**": true
  },

  "search.exclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true
  },

  "webhint.enable": false,
  "CodeGPT.apiKey": "LM Studio",
  "chatgpt.runCodexInWindowsSubsystemForLinux": true,
  "git.autofetch": true,
  "git.enabled": true,
  "geminicodeassist.agentYoloMode": true,
  "geminicodeassist.agentDebugMode": true
}
